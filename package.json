    "@types/react": "~19.2.0",
    "@types/supercluster": "^7.1.3",
    "eas-cli": "^20.0.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.13",
    "typescript": "~6.0.3"
  },
  "main": "expo-router/entry",
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true,
  "trustedDependencies": [
