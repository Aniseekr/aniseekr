    "expo-secure-store": "~56.0.4",
    "expo-sensors": "~56.0.5",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "nativewind": "preview",
    "opencc-js": "1.3.1",
    "piexif-ts": "^2.1.0",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-clarity": "4.6.2",
    "react-native-cloud-storage": "^3.0.0",
    "react-native-css": "latest",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-performance": "^6.0.0",
    "react-native-purchases": "^10.2.1",
    "react-native-reanimated": "4.3.1",
